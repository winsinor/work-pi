#!/usr/bin/env bash
# deploy — pull latest from main and restart work-dashboard
set -euo pipefail

REPO="/home/pi/work-pi"
INSTALL_DIR="/home/pi/work-dashboard"
SERVICE="work-dashboard"

cd "$REPO"

# Layout backup: save to home dir (outside the repo, outside the install dir)
# so neither git operations nor rsync can ever touch it.
BACKUP_FILE="/home/pi/work_layout.backup.json"

# Back up the live layout before anything else runs.
# The install dir's work_layout.json is the authoritative copy — it's never
# touched by rsync (excluded below) and never touched by git (different dir).
if [ -f "$INSTALL_DIR/work_layout.json" ]; then
    echo "==> Backing up work_layout.json to $BACKUP_FILE …"
    sudo rsync -a --chown=pi:pi "$INSTALL_DIR/work_layout.json" "$BACKUP_FILE"
fi

echo "==> Pulling latest …"
git fetch origin main
sudo git reset --hard origin/main

echo "==> Syncing to $INSTALL_DIR …"
# work_layout.json is intentionally excluded — the install dir's copy is the
# live layout edited via the editor and must never be overwritten by a deploy.
sudo rsync -a --exclude='.git' --exclude='config.json' --exclude='work_layout.json' --exclude='__pycache__' \
    "$REPO/" "$INSTALL_DIR/"

# Seed layout on first deploy only — never overwrite user's saved layout.
if [ ! -f "$INSTALL_DIR/work_layout.json" ]; then
    echo "==> Seeding work_layout.json from repo …"
    sudo cp "$REPO/work_layout.json" "$INSTALL_DIR/work_layout.json"
fi

echo "==> Restarting $SERVICE …"
sudo systemctl restart "$SERVICE"

echo "==> Done. Logs: journalctl -u $SERVICE -f"
