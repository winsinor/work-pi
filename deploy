#!/usr/bin/env bash
# deploy — pull latest from main and restart work-dashboard
set -euo pipefail

REPO="/home/pi/work-pi"
INSTALL_DIR="/home/pi/work-dashboard"
SERVICE="work-dashboard"

cd "$REPO"

# Back up any layout-editor changes made on the Pi to GitHub *before* pulling,
# so an incoming update can never clobber them. --chown keeps the repo file
# owned by pi (install dir runs as root) so later git commands don't choke.
if [ -f "$INSTALL_DIR/work_layout.json" ]; then
    sudo rsync -a --chown=pi:pi "$INSTALL_DIR/work_layout.json" "$REPO/work_layout.json"
    if ! git diff --quiet -- work_layout.json; then
        echo "==> Backing up work_layout.json changes to GitHub …"
        git add work_layout.json
        git commit -m "Auto-backup work_layout.json from Pi before deploy"
        git push origin main
    fi
fi

echo "==> Pulling latest …"
git pull origin main

echo "==> Syncing to $INSTALL_DIR …"
sudo rsync -a --exclude='.git' --exclude='config.json' --exclude='work_layout.json' --exclude='__pycache__' \
    "$REPO/" "$INSTALL_DIR/"

# Seed layout on first deploy only — never overwrite user's saved layout
if [ ! -f "$INSTALL_DIR/work_layout.json" ]; then
    echo "==> Seeding work_layout.json from repo …"
    sudo cp "$REPO/work_layout.json" "$INSTALL_DIR/work_layout.json"
fi

echo "==> Restarting $SERVICE …"
sudo systemctl restart "$SERVICE"

echo "==> Done. Logs: journalctl -u $SERVICE -f"
